#!/usr/bin/env sh

set -e

echo "Checking tile date freshness..."

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoLogo -NoProfile -File ./docs/refresh-tile-dates.ps1 -Check
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./docs/refresh-tile-dates.ps1 -Check
else
  echo "Error: PowerShell is required to run docs/refresh-tile-dates.ps1"
  exit 1
fi
