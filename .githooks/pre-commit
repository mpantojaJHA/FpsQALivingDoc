#!/usr/bin/env sh

set -e

echo "Running tile date refresh..."

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoLogo -NoProfile -File ./docs/refresh-tile-dates.ps1 -Apply
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./docs/refresh-tile-dates.ps1 -Apply
else
  echo "Error: PowerShell is required to run docs/refresh-tile-dates.ps1"
  exit 1
fi

git add index.html
